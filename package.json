{
  "name": "gastown",
  "version": "0.1.0",
  "private": true,
  "description": "A pixel-art survival game exploring complicity through Dr. Nyiszli's Auschwitz memoir",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "android": "npm run build && npx cap sync android && npx cap open android",
    "android:run": "npm run build && npx cap sync android && npx cap run android"
  },
  "dependencies": {
    "howler": "^2.2.4",
    "phaser": "^3.87.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/ui": "^2.1.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vitest": "^2.1.8"
  }
}
